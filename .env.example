# Environment Configuration

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/aren
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/aren

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin
# ADMIN_PASSWORD is configured separately and kept SECRET
# Never commit .env file with actual password to git
# Set this in your local .env file only
ADMIN_SALT_ROUNDS=10

# Frontend
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
