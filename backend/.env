# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database
MONGODB_URI=mongodb://localhost:27017/aren

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5500
CLIENT_URL=http://localhost:5500

# Admin Configuration - SET YOUR OWN SECRET PASSWORD
# This is only known to you, never commit this file
ADMIN_PASSWORD=your_secret_admin_password_here

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW_MS=15 * 60 * 1000
LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# File Upload
MAX_FILE_SIZE=5242880

# Environment
LOG_LEVEL=debug
